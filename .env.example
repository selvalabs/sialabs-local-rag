# App
APP_NAME=SoberanIA Labs Local RAG
APP_ENV=development
DATABASE_URL=sqlite:///./data/sialabs_local_rag.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4182,http://127.0.0.1:4182,http://localhost:4173,http://127.0.0.1:4173

# RAG
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
RETRIEVAL_TOP_K=5

# Providers: use mock/hash for CI and demos without Ollama.
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=hash

# Ollama local runtime
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma4:e2b
OLLAMA_EMBED_MODEL=embeddinggemma
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# Frontend
VITE_API_URL=http://localhost:8000
